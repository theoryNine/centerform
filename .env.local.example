# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-only, never expose to client. Find in Supabase > Settings > API.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth.js (v5 uses AUTH_* prefix)
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# Resend — magic link email provider (https://resend.com)
RESEND_API_KEY=re_...
# Must be a verified domain in your Resend account
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Internal admin API key — guards /api/admin/invites
# Generate with: openssl rand -base64-32
ADMIN_API_KEY=your-admin-api-key
